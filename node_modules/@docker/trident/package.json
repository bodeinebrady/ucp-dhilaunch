{
  "name": "@docker/trident",
  "version": "1.59.3",
  "type": "module",
  "sideEffects": [
    "./src/styles/*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "dist/",
    "src/components/**/*.tsx",
    "src/components/**/*.ts",
    "!src/components/**/*.test.tsx",
    "!src/components/**/*.test.ts",
    "contrast-matrix.json"
  ],
  "exports": {
    "./styles/*": "./dist/styles/*",
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./components/ui/*": {
      "types": "./dist/components/ui/*.d.ts",
      "import": "./dist/components/ui/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    }
  },
  "scripts": {
    "build": "tsup && bun run styles:copy",
    "styles:copy": "bun scripts/copy-styles.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "lint:check": "oxlint --type-aware --type-check",
    "conventions:check": "bun scripts/check-dds-conventions.ts",
    "conventions:check:all": "bun scripts/check-dds-conventions.ts $(find src/components storybook/stories -name '*.ts' -o -name '*.tsx' | tr '\\n' ' ')",
    "stories:contract": "bun storybook/scripts/check-storybook-story-contract.ts",
    "stories:tokens": "bun storybook/scripts/check-storybook-token-contract.ts",
    "stories:typography": "bun storybook/scripts/check-storybook-product-typography.ts",
    "stories:render-contract": "bun storybook/scripts/check-storybook-render-contract.ts",
    "stories:check": "bun run stories:contract && bun run stories:typography && bun run stories:tokens",
    "stories:ci": "bash storybook/ci/source-contracts.sh && bash storybook/ci/presentation-checks.sh",
    "codemod:stories:ast-grep": "ast-grep scan -c storybook/codemods/ast-grep/sgconfig.yml storybook/stories",
    "codemod:stories:ast-grep:fix": "ast-grep scan -c storybook/codemods/ast-grep/sgconfig.yml storybook/stories --update-all",
    "codemod:stories:reference-first": "bun storybook/scripts/codemods/storybook-reference-first.ts",
    "codemod:stories:reference-first:check": "bun storybook/scripts/codemods/storybook-reference-first.ts --check",
    "codemod:stories:manifest": "bun storybook/scripts/codemods/generate-storybook-reference-manifest.ts",
    "codemod:stories": "bun run codemod:stories:ast-grep:fix && bun run codemod:stories:reference-first && bun run codemod:stories:manifest",
    "docs:check": "bun scripts/check-docs-contract.ts",
    "docs:smoke": "bun scripts/run-adoption-smoke.ts",
    "specimen": "vite --config trident-design/vite.config.ts",
    "specimen:build": "vite build --config trident-design/vite.config.ts",
    "storybook": "storybook dev -p 6006 --config-dir storybook/.storybook",
    "build-storybook": "storybook build --config-dir storybook/.storybook",
    "test:unit": "vitest run",
    "test:storybook": "vitest run --config vitest.storybook.config.ts",
    "test:storybook:visual:run": "playwright test -c storybook/testing/playwright.visual.config.ts",
    "test:storybook:visual": "bun run build-storybook && bun run test:storybook:visual:run",
    "test:storybook:visual:update": "bun run build-storybook && bun run test:storybook:visual:run --update-snapshots",
    "test:storybook:visual:all": "STORYBOOK_VISUAL_SCOPE=all bun run test:storybook:visual",
    "check-contrast": "bun run tokens/scripts/check-contrast.ts",
    "tokens:build": "bun tokens/scripts/build-tokens.ts",
    "new-token": "bun tokens/scripts/new-token.ts",
    "token-contracts:export": "bun run scripts/export-token-contracts.ts",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "bundle-size": "bun run scripts/bundle-size.ts",
    "ci:local": "bun run lint:check && bun run fmt:check && bun run conventions:check:all && bun run stories:ci && bun run docs:check && bun run typecheck && bun run tokens:build && bun run test:unit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@shikijs/transformers": "^4.0.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "apca-w3": "^0.1.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "culori": "^4.0.2",
    "date-fns": "^4.1.0",
    "decamelize": "^6.0.1",
    "diff": "^8.0.4",
    "dompurify": "^3.4.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "slug": "^11.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": false
    }
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.1",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-mcp": "^0.4.2",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/builder-vite": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/apca-w3": "^0.1.3",
    "@types/bun": "^1.3.13",
    "@types/culori": "^4.0.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/slug": "^5.0.9",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "bun-plugin-tailwind": "^0.1.2",
    "esbuild": "^0.24.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.17.4",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "semantic-release": "^25.0.3",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.4",
    "ts-morph": "^27.0.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  },
  "packageManager": "bun@1.3.11",
  "patchedDependencies": {
    "@storybook/react-vite@10.3.3": "patches/@storybook%2Freact-vite@10.3.3.patch",
    "tsup@8.5.1": "patches/tsup@8.5.1.patch"
  },
  "trustedDependencies": [
    "@ast-grep/cli",
    "bun"
  ]
}
